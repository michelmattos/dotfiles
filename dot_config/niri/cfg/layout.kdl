    layout {
        gaps 8
        center-focused-column "never"

        background-color "transparent" // <- needed for noctalia-shell to set wallpaper

        preset-column-widths {
            proportion 0.33333
            proportion 0.5
            proportion 0.66667
        }

        default-column-width { proportion 0.5; }

        struts {
            left 0
            right 0
            top -4
            bottom 2
        }
    }
